# Notion CMS Configuration
# Get your API key from: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your_api_key_here

# Get your database ID from the URL when viewing your database
# Example: https://notion.so/myworkspace/a8aec43384f447ed84390e8e42c2e089?v=...
#                                        ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
NOTION_DATABASE_ID=your_database_id_here
